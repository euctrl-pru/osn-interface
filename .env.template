# Template for osn-interface credentials.
# Copy this file to .env and fill in your own values:
#     cp .env.template .env
# .env is git-ignored and must never be committed.
#
# Load into an R session with:
#     osninterface::osn_load_env()   # or readRenviron(".env")

# --- osn-ec-datadump source (default) --------------------------------------
# DuckDB httpfs reads parquet from s3.opensky-network.org.
# OSN_USERNAME = S3 access key id, OSN_KEY = S3 secret access key.
OSN_USERNAME=
OSN_KEY=

# --- osn-historical-trino source -------------------------------------------
# Used when osn_connect(source = "osn-historical-trino"). Backed by
# trino.opensky-network.org (catalog minio, schema osky) via RPresto.
# These are your OpenSky Trino LOGIN credentials (username + password),
# NOT S3 keys. Request access at
# https://opensky-network.org/my-opensky/request-data
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# OSN REST API oauth2 client (optional; only for REST endpoints).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
